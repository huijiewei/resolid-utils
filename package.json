{
  "name": "@resolid/utils",
  "version": "1.2.7",
  "description": "Common utils",
  "keywords": [
    "javascript",
    "nodejs",
    "resolid",
    "typescript"
  ],
  "homepage": "https://www.resolid.tech",
  "license": "MIT",
  "author": "Huijie Wei",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/huijiewei/resolid-utils.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "format": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@formkit/tempo": "^1.0.0",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@resolid/config": "^5.0.3",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@types/node": "^24.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "lefthook": "^2.1.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ],
    "overrides": {
      "safer-buffer": "npm:@nolyfill/safer-buffer@^1"
    }
  }
}
